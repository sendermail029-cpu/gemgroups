# GEM Group Projects - Environment Variables
# Copy this file to .env.local and fill in your values

# Site URL
NEXT_PUBLIC_SITE_URL=https://gemgroupprojects.com

# Contact
NEXT_PUBLIC_WHATSAPP=919885524320
NEXT_PUBLIC_PHONE=+919885524320
NEXT_PUBLIC_EMAIL=info@gemgroupprojects.com

# Google Maps (optional - for embedded maps)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Lead delivery integrations (optional)
# Set webhook endpoints if you want lead submissions forwarded beyond data/leads.json
LEADS_EMAIL_WEBHOOK_URL=
LEADS_WHATSAPP_WEBHOOK_URL=
LEADS_GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbx5XZZuWqiDlcBl0rXLIu_CCD5bRHwl_SVfP3aLMtw0w4OHW4GpTFZ7Xo9oBEqqnPQt8A/exec
